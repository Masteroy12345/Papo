datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  OFFLINE_PENDING
  OFFLINE_CONFIRMED
}

model User {
  userId     Int        @id @default(autoincrement())
  username   String     @unique
  email      String     @unique
  phone      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  kycStatus  KycStatus  @default(PENDING)
  hash       String
  keyEnc     String?
  wallets    Wallet[]
}

model Wallet {
  walletId       Int           @id @default(autoincrement())
  address        String        @unique
  userId         Int
  user           User          @relation(fields: [userId], references: [userId], onDelete: Cascade)
  publicKey      String
  privateKeyEnc  String
  passPhrase     String?
  createdAt      DateTime      @default(now())
  balance        Decimal       @default(0.0)
  currency       String
  sentTrans      Transaction[] @relation("SentTransactions")
  receivedTrans  Transaction[] @relation("ReceivedTransactions")
}

model Token {
  tokenId      Int           @id @default(autoincrement())
  mintAddress  String?
  name         String
  symbol       String        @unique
  decimals     Int
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  transactionId  Int               @id @default(autoincrement())
  walletFrom     Int
  walletTo       Int
  sender         Wallet            @relation("SentTransactions", fields: [walletFrom], references: [walletId], onDelete: Cascade)
  receiver       Wallet            @relation("ReceivedTransactions", fields: [walletTo], references: [walletId], onDelete: Cascade)
  tokenId        Int
  token          Token             @relation(fields: [tokenId], references: [tokenId], onDelete: Cascade)
  amount         Decimal
  signature      String
  status         TransactionStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  confirmedAt    DateTime?
  fee            Decimal           @default(0.0)
}
